# ------------------------------
# CineStream Backend — environment
# ------------------------------
# Copy to `.env` and fill in as needed.

# HTTP
PORT=4000
CORS_ORIGIN=*

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Seeded admin user (used only on first run when the users collection is empty)
ADMIN_EMAIL=admin@cinestream.app
ADMIN_PASSWORD=admin123

# MongoDB
# Local:    mongodb://127.0.0.1:27017/cinestream
# Atlas:    mongodb+srv://<user>:<pass>@<cluster>/cinestream?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/cinestream

# ------------------------------
# OAuth — leave blank to disable the corresponding /auth/social/* endpoint
# ------------------------------

# Google OAuth 2.0 client IDs (comma-separated allow-list of audiences we accept).
# Include one per platform used to sign users in — typically iOS + Android + Web.
# Create these in Google Cloud Console → APIs & Services → Credentials.
# GOOGLE_CLIENT_IDS=1234-web.apps.googleusercontent.com,1234-ios.apps.googleusercontent.com,1234-android.apps.googleusercontent.com

# Apple client IDs (comma-separated). For native iOS sign-in this is your app bundle ID.
# APPLE_CLIENT_IDS=org.reactjs.native.example.CineStream
